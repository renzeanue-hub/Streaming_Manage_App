rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isEditor() {
      return isSignedIn()
        && get(/databases/$(database)/documents/config/editors)
             .data.uids[request.auth.uid] == true;
    }

    match /config/editors {
      allow read: if isSignedIn();
      allow write: if false; // 追加はコンソールで運用（安全）
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /streams/{id} {
      allow read: if true;
      allow create, update, delete: if isEditor();
    }
  }
}